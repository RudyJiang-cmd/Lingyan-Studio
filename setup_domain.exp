#!/usr/bin/expect -f
set timeout 30
set ip "119.45.247.15"
set user "ubuntu"
set domain "lingfun.fun"

spawn ssh -i TRAE.pem -o StrictHostKeyChecking=no $user@$ip
expect "*$*"
send "sudo sed -i 's/server_name _;/server_name $domain www.$domain;/' /etc/nginx/sites-available/default\r"
expect "*$*"
send "sudo systemctl reload nginx\r"
expect "*$*"
send "exit\r"
expect eof
